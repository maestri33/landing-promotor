# URL do app (destino do CTA "Quero ser promotor"). Sem barra final.
# Deve apontar para o cadastro do candidato a promotor (funil candidate /
# grupo "collaborators" da API). Sem essa variável: dev usa
# http://localhost:3000, build usa https://candidato.v7m.org
PUBLIC_APP_URL=https://app.v7m.org

# Domínio canônico do site (canonical, Open Graph, sitemap.xml, robots.txt)
SITE=https://job.v7m.org

# ----------------------------------------------------------------------------
# Comissão do promotor — FONTE ÚNICA dos números da seção "Quanto dá pra ganhar"
# e da calculadora. Devem espelhar finance/config.py em produção.
# (PUBLIC_ porque a calculadora roda no client.)
# ----------------------------------------------------------------------------
# Comissão direta por matrícula PAGA (R$)
PUBLIC_COMMISSION_DIRECT=100
# Bônus flat (R$) concedido por bloco de indicações pagas na semana
PUBLIC_BONUS_FLAT=500
# Tamanho do bloco que destrava o bônus (ex.: 5 = a cada 5 pagas)
PUBLIC_BONUS_THRESHOLD=5
# Bônus repete a cada bloco?
#   false = degrau único, semanal: atingiu o threshold na semana → paga 1x;
#           acima do threshold (10, 50, 100) o bônus continua sendo 1x só.
#   true  = a cada bloco (+500, +1000, ...).
PUBLIC_BONUS_REPEATS=false

# Fechamento semanal do Pix — espelha closing_weekday/closing_hour de
# finance/config.py. Mude aqui se mudar lá (promessa de dinheiro na página).
PUBLIC_CLOSING_LABEL=toda sexta, às 18h

# ----------------------------------------------------------------------------
# Identificação legal do fornecedor (CDC art. 31 / LGPD art. 9)
# ⚠️ BLOQUEADOR DE PRODUÇÃO: sem PUBLIC_CNPJ real a linha do CNPJ não aparece.
#    NUNCA usar placeholder (00.000.000/0001-00) — risco jurídico.
# ----------------------------------------------------------------------------
# Razão/nome da PJ que opera o programa
PUBLIC_LEGAL_NAME=V7M Empresarial
# CNPJ real, formatado (ex.: 12.345.678/0001-90). Vazio = não renderiza.
PUBLIC_CNPJ=48.811.016/0001-00
# E-mail de contato (SAC)
PUBLIC_CONTACT_EMAIL=contato@v7m.org
# WhatsApp do SAC, só dígitos com DDI/DDD (ex.: 5511999999999). Vazio = oculta.
PUBLIC_CONTACT_WHATSAPP=5511920062177
