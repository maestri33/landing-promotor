---
/**
 * Seção 1 — Como funciona. 3 passos em cards levemente rotacionados
 * (editorial), linha conectora que se desenha no scroll, watermark 01.
 * Espelha a mecânica real: recebe link → compartilha → ganha por Pix.
 */
import { CLOSING_LABEL } from '../config';

const steps = [
  {
    title: 'Receba seu link',
    text: 'Depois de aprovado, você ganha um link só seu. É a sua ferramenta de trabalho — uma só.',
  },
  {
    title: 'Compartilhe com quem quer estudar',
    text: 'WhatsApp, redes sociais, boca a boca. Quem clica no seu link e se matricula fica amarrado a você.',
  },
  {
    title: 'Ganhe e receba no Pix',
    text: `Cada matrícula paga vira comissão sua — mais bônus se indicar bastante na semana. O dinheiro cai na sua chave Pix ${CLOSING_LABEL}.`,
  },
];

/* micro-loops CSS: link que se desenha, nós de compartilhar pulsando,
   seta de Pix entrando */
const icons = [
  `<path class="i-link" pathLength="1" d="M9.5 14.5l5-5M8 13l-2.2 2.2a3.3 3.3 0 0 0 4.7 4.7L12.7 18M11.3 6l2.2-2.2a3.3 3.3 0 0 1 4.7 4.7L16 10.7"></path>`,
  `<circle cx="6.5" cy="12" r="2.4"></circle><circle cx="17.5" cy="6" r="2.4"></circle><circle cx="17.5" cy="18" r="2.4"></circle><path class="i-share" d="M8.7 10.9l6.6-3.6M8.7 13.1l6.6 3.6"></path>`,
  `<rect x="3.2" y="6.5" width="17.6" height="11" rx="2.4"></rect><circle cx="12" cy="12" r="2.6"></circle><path class="i-pix" d="M12 2.6v3M12 18.4v3" stroke-linecap="round"></path>`,
];
---

<section id="como-funciona" class="steps section" aria-labelledby="steps-title" data-section="como-funciona">
  <span class="sec-num" aria-hidden="true" data-n="01"></span>
  <div class="container">
    <p class="kicker steps-kicker" data-reveal>Como funciona</p>
    <h2 id="steps-title" data-reveal>Três passos até o seu Pix</h2>

    <div class="steps-wrap" data-reveal style="--d: 1">
      <svg class="steps-line" viewBox="0 0 100 12" preserveAspectRatio="none" aria-hidden="true">
        <path
          d="M2 6 C 25 1, 42 11, 50 6 S 80 1, 98 6"
          fill="none"
          stroke="var(--green)"
          stroke-opacity="0.35"
          stroke-width="0.6"
          stroke-dasharray="1.4 1"
          pathLength="100"></path>
      </svg>

      <ol class="steps-grid">
        {steps.map((step, i) => (
          <li data-reveal style={`--d: ${i + 1}`}>
            <article class="step-card">
              <span class="step-n" aria-hidden="true"><i>{i + 1}</i></span>
              <span class="step-watermark" aria-hidden="true" data-n={`0${i + 1}`}></span>
              <svg
                class="step-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[i]}
              />
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          </li>
        ))}
      </ol>
    </div>

    <p class="steps-note" data-reveal style="--d: 4">
      Sem estoque · sem mensalidade · sem vender nada · você só compartilha
    </p>
  </div>
</section>

<style>
  .steps {
    background:
      radial-gradient(rgb(0 115 77 / 0.07) 1px, transparent 1.5px) 0 0 / 26px 26px,
      var(--paper);
    overflow: clip;
  }

  .steps .sec-num {
    color: var(--green);
  }

  #steps-title {
    font-size: var(--text-h2-sm);
  }

  .steps-kicker {
    color: var(--green);
  }

  .steps-wrap {
    position: relative;
    margin-top: 3.4rem;
  }

  .steps-line {
    display: none;
    position: absolute;
    inset-inline: 4%;
    top: -2.4rem;
    height: 3.4rem;
    width: 92%;
    overflow: visible;
  }

  @media (min-width: 880px) {
    .steps-line {
      display: block;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .steps-wrap .steps-line path {
      stroke-dashoffset: 100;
    }

    :global(html.js) .steps-wrap.in-view .steps-line path {
      transition: stroke-dashoffset 1.4s var(--ease-out) 0.3s;
      stroke-dashoffset: 0;
    }
  }

  .steps-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
  }

  /* mobile: linha do tempo vertical conectando os passos */
  @media (max-width: 879px) {
    .steps-grid {
      position: relative;
      padding-left: 1.3rem;
    }

    .steps-grid::before {
      content: '';
      position: absolute;
      left: 0.28rem;
      top: 1.2rem;
      bottom: 1.2rem;
      border-left: 2px dashed rgb(0 115 77 / 0.35);
    }

    .steps-grid li {
      position: relative;
    }

    .steps-grid li::before {
      content: '';
      position: absolute;
      left: -1.35rem;
      top: 1.5rem;
      width: 0.72rem;
      height: 0.72rem;
      background: var(--yellow);
      border: 2px solid var(--green);
      transform: rotate(45deg);
      border-radius: 2px;
    }
  }

  .step-card {
    position: relative;
    height: 100%;
    background: var(--paper-soft);
    border: 1px solid var(--line-light);
    border-radius: var(--radius);
    padding: 2.1rem 1.6rem 1.8rem;
    overflow: clip;
    box-shadow: 0 14px 34px -22px rgb(11 18 32 / 0.25);
    transition:
      transform 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }

  @media (min-width: 880px) {
    .steps-grid li:nth-child(1) .step-card {
      transform: rotate(-1.2deg);
    }

    .steps-grid li:nth-child(2) .step-card {
      transform: rotate(0.9deg) translateY(0.6rem);
    }

    .steps-grid li:nth-child(3) .step-card {
      transform: rotate(-0.7deg);
    }

    .steps-grid li .step-card:hover {
      transform: rotate(0deg) translateY(-6px);
      box-shadow: 0 24px 44px -22px rgb(11 18 32 / 0.35);
    }
  }

  .step-n {
    position: absolute;
    top: 1.3rem;
    right: 1.4rem;
    width: 2.1rem;
    height: 2.1rem;
    display: grid;
    place-items: center;
    background: var(--yellow);
    border-radius: 7px;
    transform: rotate(45deg);
    box-shadow: 0 6px 14px -6px rgb(255 196 0 / 0.7);
  }

  .step-n i {
    font-style: normal;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--ink);
    transform: rotate(-45deg);
  }

  .step-watermark::after {
    content: attr(data-n);
  }

  .step-watermark {
    position: absolute;
    bottom: -1.6rem;
    right: 0.4rem;
    font-family: var(--font-display);
    font-size: 6.5rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.3px rgb(0 115 77 / 0.14);
    pointer-events: none;
    user-select: none;
  }

  .step-icon {
    width: 3.2rem;
    height: 3.2rem;
    color: var(--green);
    margin-bottom: 1.1rem;
  }

  /* micro-loops: quase imperceptíveis, mas a página respira.
     :global porque o conteúdo vem via set:html (sem scoping do Astro) */
  @media (prefers-reduced-motion: no-preference) {
    .step-icon :global(.i-link) {
      stroke-dasharray: 1;
      animation: step-link 4.6s ease-in-out infinite;
    }

    .step-icon :global(.i-share) {
      animation: step-share 3.4s ease-in-out infinite;
    }

    .step-icon :global(.i-pix) {
      transform-box: view-box;
      transform-origin: 12px 12px;
      animation: step-pix 3s ease-in-out infinite;
    }
  }

  @keyframes step-link {
    0%,
    8% {
      stroke-dashoffset: 1;
    }
    28%,
    82% {
      stroke-dashoffset: 0;
    }
    96%,
    100% {
      stroke-dashoffset: 1;
    }
  }

  @keyframes step-share {
    50% {
      opacity: 0.35;
    }
  }

  @keyframes step-pix {
    50% {
      transform: translateY(-2px) scale(1.08);
    }
  }

  .step-card h3 {
    font-size: var(--text-h3);
    margin-bottom: 0.55rem;
    padding-right: 2.4rem;
  }

  .step-card p {
    color: var(--muted-on-light);
    font-size: 0.98rem;
  }

  .steps-note {
    margin-top: 2.6rem;
    font-weight: 700;
    color: var(--green);
    font-size: 0.95rem;
  }
</style>
