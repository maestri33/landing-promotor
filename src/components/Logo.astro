---
/**
 * Logotipo: losango da bandeira estilizado + wordmark + selo do programa.
 * variant="light" para fundos escuros, "dark" para fundos claros.
 */
import { BRAND, PROGRAM } from '../config';

interface Props {
  variant?: 'light' | 'dark';
  withLink?: boolean;
}
const { variant = 'light', withLink = true } = Astro.props;
const Tag = withLink ? 'a' : 'span';
const [brandA, ...brandRest] = BRAND.split(' ');
const brandB = brandRest.join(' ');
---

<Tag class={`logo logo--${variant}`} {...withLink ? { href: '/', 'aria-label': `${BRAND} ${PROGRAM} — página inicial` } : {}}>
  <svg class="logo-mark" viewBox="0 0 48 48" width="34" height="34" aria-hidden="true" fill="none">
    <path
      d="M24 3.5 44.5 24 24 44.5 3.5 24Z"
      stroke="var(--yellow)"
      stroke-width="3.6"
      stroke-linejoin="round"></path>
    <path
      class="logo-plus"
      d="M24 15v18M15 24h18"
      stroke-width="4"
      stroke-linecap="round"></path>
  </svg>
  <span class="logo-word">{brandA}&nbsp;<b>{brandB}</b></span>
  <span class="logo-tag">{PROGRAM}</span>
</Tag>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }

  /* sinal de mais (somar/ganhar) se desenha na carga */
  @media (prefers-reduced-motion: no-preference) {
    .logo-plus {
      stroke-dasharray: 40;
      stroke-dashoffset: 40;
      animation: logo-draw 0.6s var(--ease-out) 0.35s forwards;
    }
  }

  @keyframes logo-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .logo-word {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .logo-tag {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    background: var(--yellow);
    color: var(--ink);
    align-self: center;
  }

  .logo--light .logo-word {
    color: var(--paper);
  }

  .logo--light .logo-plus {
    stroke: var(--paper);
  }

  .logo--light .logo-word b {
    color: var(--yellow);
  }

  .logo--dark .logo-word {
    color: var(--ink);
  }

  .logo--dark .logo-plus {
    stroke: var(--green);
  }

  .logo--dark .logo-word b {
    color: var(--green);
  }
</style>
