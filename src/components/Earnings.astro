---
/**
 * Seção 2 — Quanto dá pra ganhar. Explica o modelo (comissão direta + bônus
 * de volume) e traz uma calculadora. TODOS os números vêm de src/config.ts
 * (que lê o .env) — fonte única. Sem JS: tabela estática responde.
 * Regra de copy: nenhuma promessa de renda; é simulação pela mecânica real.
 */
import CtaButton from './CtaButton.astro';
import {
  COMMISSION_DIRECT,
  BONUS_FLAT,
  BONUS_THRESHOLD,
  BONUS_REPEATS,
  CLOSING_LABEL,
  weeklyEarnings,
  brl,
} from '../config';

const DEFAULT_N = BONUS_THRESHOLD; // começa mostrando 1 bloco de bônus
const start = weeklyEarnings(DEFAULT_N);

const bonusRule = BONUS_REPEATS
  ? `a cada ${BONUS_THRESHOLD} pagas na semana`
  : `ao bater ${BONUS_THRESHOLD} pagas na semana (1x por semana)`;

// Tabela de fallback (sem JS) — mesmos números da calculadora
const fallbackRows = [1, BONUS_THRESHOLD, BONUS_THRESHOLD * 2, BONUS_THRESHOLD * 3].map((n) => ({
  n,
  ...weeklyEarnings(n),
}));
---

<section id="ganhos" class="earn section on-dark grain" aria-labelledby="earn-title" data-section="ganhos">
  <span class="sec-num" aria-hidden="true" data-n="02"></span>
  <div class="container earn-inner">
    <p class="kicker earn-kicker" data-reveal>Quanto dá pra ganhar</p>
    <h2 id="earn-title" data-reveal>Você controla o quanto entra</h2>
    <p class="earn-lead" data-reveal style="--d: 1">
      Cada pessoa que você ajuda a voltar a estudar vira renda no seu Pix. São
      duas formas de ganhar, somadas toda semana: quanto mais gente você indica
      e conclui a matrícula, mais cai na sua conta.
    </p>

    <div class="earn-models" data-reveal style="--d: 2">
      <div class="model">
        <span class="model-tag">Comissão direta</span>
        <p class="model-value">{brl(COMMISSION_DIRECT)}</p>
        <p class="model-desc">por <strong>cada matrícula paga</strong> que vier do seu link</p>
      </div>
      <span class="model-plus" aria-hidden="true">+</span>
      <div class="model">
        <span class="model-tag">Bônus de volume</span>
        <p class="model-value">{brl(BONUS_FLAT)}</p>
        <p class="model-desc">de bônus <strong>{bonusRule}</strong></p>
      </div>
    </div>

    <!-- Calculadora (com JS) -->
    <div class="calc calc-interactive" data-spotlight data-reveal style="--d: 3">
      <label class="calc-q" for="calc-range">Quantas matrículas pagas por semana?</label>

      <div class="calc-rangewrap">
        <span class="calc-hint" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Arraste pra simular
        </span>
        <input
          id="calc-range"
          class="calc-range"
          type="range"
          min="1"
          max="20"
          step="1"
          value={DEFAULT_N}
          data-calc-range
          aria-label="Matrículas pagas por semana"
        />
        <div class="calc-ticks" aria-hidden="true"><span>1</span><span>10</span><span>20</span></div>
      </div>

      <div class="calc-presets" role="group" aria-label="Valores rápidos de matrículas por semana">
        {[1, 5, 10, 20].map((n) => (
          <button
            type="button"
            class="calc-preset"
            data-calc-preset={n}
            aria-pressed={n === DEFAULT_N ? 'true' : 'false'}
          >
            {n}
          </button>
        ))}
        <span class="calc-preset-label" aria-hidden="true">por semana</span>
      </div>

      <p class="calc-paidline">
        <strong data-calc-paid>{DEFAULT_N}</strong> matrículas pagas na semana
      </p>

      <div class="calc-result">
        <span class="calc-result-label">você recebe</span>
        <p class="calc-total"><span data-calc-total>{brl(start.total)}</span></p>
        <span class="calc-result-when">no seu Pix · {CLOSING_LABEL}</span>
      </div>

      <dl class="calc-break">
        <div>
          <dt>Comissão ({brl(COMMISSION_DIRECT)} cada)</dt>
          <dd data-calc-direct>{brl(start.direct)}</dd>
        </div>
        <div class="calc-bonus-row on" data-calc-bonus-row>
          <dt>
            Bônus de volume
            <span class="calc-bonus-badge" data-calc-bonus-badge aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Desbloqueado
            </span>
          </dt>
          <dd data-calc-bonus>{brl(start.bonus)}</dd>
        </div>
      </dl>

      <p class="calc-note">
        Simulação pelos valores atuais do programa. Não é promessa de renda:
        você ganha conforme indica e as pessoas pagam a matrícula.
      </p>
    </div>

    <!-- Tabela estática (sem JS) -->
    <div class="calc calc-fallback">
      <p class="calc-q">Quanto dá em uma semana</p>
      <table class="calc-table">
        <thead>
          <tr><th>Matrículas pagas</th><th>Você recebe</th></tr>
        </thead>
        <tbody>
          {fallbackRows.map((row) => (
            <tr>
              <td>{row.n}</td>
              <td>
                {brl(row.total)}
                {row.bonus > 0 && <span class="calc-table-bonus"> (com bônus)</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="calc-note">
        Mesma conta da calculadora: os valores já somam o bônus da semana.
        Comissão de {brl(COMMISSION_DIRECT)} por matrícula paga + {brl(BONUS_FLAT)}
        {' '}{bonusRule}. Não é promessa de renda.
      </p>
    </div>

    <div class="earn-cta" data-reveal style="--d: 4">
      <CtaButton position="ganhos" class="btn-xl" />
      <p class="microcopy">Grátis pra entrar · você recebe por Pix toda semana</p>
    </div>
  </div>
</section>

<style>
  .earn {
    background:
      radial-gradient(40rem 30rem at 16% 6%, rgb(240 212 147 / 0.16), transparent 58%),
      radial-gradient(44rem 34rem at 84% 30%, rgb(217 177 90 / 0.16), transparent 58%),
      radial-gradient(52rem 40rem at 50% 108%, rgb(168 123 46 / 0.26), transparent 62%),
      var(--black);
    color: var(--paper);
    text-align: center;
    overflow: clip;
  }

  .earn .sec-num {
    color: var(--paper);
  }

  .earn-kicker {
    color: var(--yellow);
  }

  .earn-inner {
    max-width: 46rem;
  }

  #earn-title {
    font-size: var(--text-h2-sm);
  }

  .earn-lead {
    color: var(--muted-on-dark);
    font-size: var(--text-lg);
    margin-top: 1rem;
    margin-inline: auto;
    max-width: 40ch;
  }

  /* dois modelos lado a lado, com "+" entre eles */
  .earn-models {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.6rem;
  }

  .model {
    flex: 1 1 14rem;
    background: rgb(255 255 255 / 0.05);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: var(--radius);
    padding: 1.5rem 1.2rem;
  }

  .model-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 0.5rem;
  }

  .model-value {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 1.6rem + 2.6vw, 3.2rem);
    line-height: 1;
    color: var(--paper);
  }

  .model-desc {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    color: var(--muted-on-dark);
  }

  .model-desc strong {
    color: var(--paper);
  }

  .model-plus {
    align-self: center;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--yellow);
  }

  /* mobile: empilha em coluna (model → + → model) para o "+" virar operação
     aritmética centralizada, não um botão solto flutuando à direita do card */
  @media (max-width: 560px) {
    .earn-models {
      flex-direction: column;
      align-items: stretch;
    }
    .model-plus {
      transform: rotate(90deg);
    }
  }

  /* calculadora */
  .calc {
    margin-top: 1.8rem;
    text-align: left;
    background:
      radial-gradient(
        26rem circle at var(--mx, 50%) var(--my, 0%),
        rgb(217 177 90 / 0.09),
        transparent 65%
      ),
      linear-gradient(180deg, var(--ink-soft), var(--ink));
    border: 1px solid rgb(217 177 90 / 0.3);
    border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 4vw, 2.4rem);
  }

  /* alterna interativa vs. estática conforme houver JS */
  .calc-fallback {
    display: none;
  }

  :global(html:not(.js)) .calc-interactive {
    display: none;
  }

  :global(html:not(.js)) .calc-fallback {
    display: block;
  }

  .calc-q {
    display: block;
    font-weight: 700;
    font-size: 1.02rem;
    color: var(--paper);
    margin-bottom: 1.2rem;
  }

  .calc-rangewrap {
    margin-bottom: 0.6rem;
    position: relative;
  }

  .calc-hint {
    position: absolute;
    top: -0.05rem;
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.32em 0.7em;
    border: 1px solid rgb(217 177 90 / 0.35);
    border-radius: 999px;
    background: rgb(217 177 90 / 0.08);
    color: var(--yellow);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
  }

  .calc-hint svg {
    width: 0.95em;
    height: 0.95em;
  }

  /* some assim que o usuário mexe — não fica mais pedindo atenção */
  :global(html.js) .calc.touched .calc-hint {
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
  }

  .calc-range {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--yellow) 0 var(--calc-fill, 22%),
      rgb(255 255 255 / 0.16) var(--calc-fill, 22%) 100%
    );
    cursor: pointer;
    touch-action: pan-y;
  }

  .calc-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--yellow);
    border: 4px solid var(--ink);
    box-shadow: 0 4px 12px -2px rgb(217 177 90 / 0.7);
  }

  .calc-range::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--yellow);
    border: 4px solid var(--ink);
  }

  .calc-range:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 6px;
  }

  .calc-ticks {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    color: var(--muted-on-dark);
    margin-top: 0.4rem;
  }

  .calc-presets {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.9rem;
  }

  .calc-preset {
    appearance: none;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.04);
    color: var(--paper);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.5em 1.05em;
    border-radius: 999px;
    cursor: pointer;
    min-width: 3rem;
    transition:
      background 0.18s var(--ease-out),
      border-color 0.18s var(--ease-out),
      color 0.18s var(--ease-out);
  }

  .calc-preset:hover {
    border-color: var(--yellow);
  }

  .calc-preset[aria-pressed='true'] {
    background: var(--yellow);
    border-color: var(--yellow);
    color: var(--ink);
  }

  .calc-preset:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 3px;
  }

  .calc-preset-label {
    margin-left: 0.2rem;
    font-size: 0.82rem;
    color: var(--muted-on-dark);
  }

  .calc-paidline {
    font-size: 0.95rem;
    color: var(--muted-on-dark);
  }

  .calc-paidline strong {
    color: var(--yellow);
    font-size: 1.1rem;
  }

  .calc-result {
    margin-top: 1.2rem;
    text-align: center;
    padding: 1.2rem;
    border-radius: var(--radius);
    background: rgb(168 123 46 / 0.18);
    border: 1px solid rgb(168 123 46 / 0.4);
  }

  .calc-result-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-on-dark);
  }

  .calc-total {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 2rem + 4vw, 4.4rem);
    line-height: 1.05;
    color: var(--yellow);
    margin: 0.2rem 0;
  }

  .calc-result-when {
    font-size: 0.86rem;
    color: var(--paper);
  }

  .calc-break {
    margin: 1.3rem 0 0;
    display: grid;
    gap: 0.55rem;
  }

  .calc-break div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px dashed rgb(255 255 255 / 0.14);
    padding-bottom: 0.4rem;
  }

  .calc-break dt {
    color: var(--muted-on-dark);
    font-size: 0.92rem;
  }

  .calc-break dd {
    margin: 0;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--paper);
  }

  /* linha de bônus apaga quando o bônus é zero */
  .calc-bonus-row {
    opacity: 0.4;
    transition: opacity 0.3s var(--ease-out);
  }

  .calc-bonus-row.on {
    opacity: 1;
  }

  .calc-bonus-row.on dd {
    color: var(--yellow);
  }

  /* badge "Desbloqueado" — só visível com .on; some quando o bônus zera */
  .calc-bonus-badge {
    display: none;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
    padding: 0.15em 0.55em;
    border: 1px solid rgb(217 177 90 / 0.55);
    border-radius: 999px;
    background: rgb(217 177 90 / 0.14);
    color: var(--gold-soft);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    vertical-align: middle;
  }

  .calc-bonus-row.on .calc-bonus-badge {
    display: inline-flex;
  }

  .calc-bonus-badge svg {
    width: 0.85em;
    height: 0.85em;
  }

  /* pulse único quando o bônus destrava (JS dispara .just-unlocked por 1.2s) */
  @media (prefers-reduced-motion: no-preference) {
    .calc-bonus-row.on.just-unlocked dd {
      animation: bonus-pulse 1.2s var(--ease-out);
    }

    .calc-bonus-row.on.just-unlocked .calc-bonus-badge {
      animation: bonus-badge-pop 1.2s var(--ease-out);
    }
  }

  @keyframes bonus-pulse {
    0% {
      transform: scale(1);
    }
    35% {
      transform: scale(1.18);
      text-shadow: 0 0 16px rgb(217 177 90 / 0.6);
    }
    100% {
      transform: scale(1);
      text-shadow: none;
    }
  }

  @keyframes bonus-badge-pop {
    0% {
      transform: scale(0.6);
      opacity: 0;
    }
    40% {
      transform: scale(1.1);
      opacity: 1;
    }
    70%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .calc-note {
    margin-top: 1.2rem;
    font-size: 0.8rem;
    color: var(--muted-on-dark);
  }

  /* tabela de fallback */
  .calc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .calc-table th,
  .calc-table td {
    text-align: left;
    padding: 0.7rem 0.4rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.14);
  }

  .calc-table th {
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-on-dark);
  }

  .calc-table td:last-child {
    font-weight: 700;
    color: var(--yellow);
    font-family: var(--font-display);
  }

  .calc-table-bonus {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--muted-on-dark);
  }

  .earn-cta {
    margin-top: 2.2rem;
  }

  .earn .microcopy {
    color: var(--muted-on-dark);
  }
</style>
