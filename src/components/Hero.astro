---
/**
 * Seção 1 — O gancho.
 * "Indique." vazado (o gesto) → "Receba." sólido com swoosh (o resultado).
 * Glow + grain + chips + marquee + celular mostrando o ciclo (link → Pix).
 * Tudo CSS; roda sem JS; some em reduced-motion.
 */
import CtaButton from './CtaButton.astro';
import PixPhone from './PixPhone.astro';
import Marquee from './Marquee.astro';
import { brl, COMMISSION_DIRECT, PRODUCT_NAME } from '../config';

const LINE_1 = 'Indique.';
const LINE_2 = 'Receba.';
const chips = ['Grátis pra entrar', 'Pix toda semana', 'Tudo pelo celular'];
const valor = brl(COMMISSION_DIRECT);
---

<section id="hero" class="hero on-dark grain" aria-labelledby="hero-title" data-section="hero">
  <div class="hero-decor" aria-hidden="true">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
    <svg class="hero-diamonds" viewBox="0 0 900 900" fill="none">
      <g stroke="#ffffff" stroke-opacity="0.05" stroke-width="2">
        <path d="M450 50 850 450 450 850 50 450Z"></path>
        <path d="M450 140 760 450 450 760 140 450Z"></path>
        <path d="M450 230 670 450 450 670 230 450Z"></path>
      </g>
      <path
        d="M450 320 580 450 450 580 320 450Z"
        stroke="var(--yellow)"
        stroke-opacity="0.3"
        stroke-width="3"></path>
      <path
        d="M408 452l34 34 78-78"
        stroke="var(--yellow)"
        stroke-opacity="0.45"
        stroke-width="7"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </div>

  <div class="hero-phone">
    <PixPhone />
  </div>

  <div class="container hero-inner">
    <p class="hero-eyebrow anim-up" style="--i: 0">
      <span class="dot" aria-hidden="true"></span>
      Programa de Promotores · V7M
    </p>

    <h1 id="hero-title" class="hero-title">
      <span class="sr-only">{LINE_1} {LINE_2}</span>
      <span aria-hidden="true" class="hero-line hero-line--ghost">
        <span class="w ghost" style="--i: 1">{LINE_1}</span>
      </span>
      <span aria-hidden="true" class="hero-line">
        <span class="w w-accent" style="--i: 2">
          {LINE_2}
          <svg class="swoosh" viewBox="0 0 220 24" fill="none" preserveAspectRatio="none">
            <path
              d="M4 17 C60 8, 150 6, 216 12"
              stroke="var(--yellow)"
              stroke-width="7"
              stroke-linecap="round"
              pathLength="1"></path>
          </svg>
        </span>
      </span>
    </h1>

    <p class="hero-sub anim-up" style="--i: 3">
      Indique o {PRODUCT_NAME} pelo celular, no seu tempo — o curso pra concluir
      o ensino fundamental ou o médio. A pessoa se matricula e
      <strong>você ganha por matrícula paga</strong>. Sem estoque, sem vender nada.
    </p>

    <ul class="hero-chips anim-up" style="--i: 4">
      {chips.map((chip, i) => (
        <li class="chip" style={`--f: ${i}`}>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12.5l4.5 4.5L19 7.5"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          {chip}
        </li>
      ))}
    </ul>

    <div class="hero-cta anim-up" style="--i: 5">
      <CtaButton position="hero" class="btn-xl" />
      <p class="microcopy">
        <strong>{valor} por matrícula paga</strong> · você recebe por Pix toda semana
      </p>
      <p class="hero-time">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
          <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <span>Cadastro em <strong>1 minuto</strong> pelo celular · sem senha</span>
      </p>
    </div>
  </div>

  <a class="scroll-cue" href="#como-funciona" aria-label="Rolar para a próxima seção">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M6 9.5l6 6 6-6"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <div class="hero-marquee">
    <Marquee
      items={['Indique matrículas', 'Receba por Pix', 'Sem vender nada', 'Grátis pra entrar', 'Trabalhe pelo celular', 'Pagamento toda semana']}
      variant="yellow"
      speed={30}
    />
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* topo respeita notch/Dynamic Island (viewport-fit=cover no Base) */
    padding-top: max(clamp(7rem, 16vh, 9rem), calc(env(safe-area-inset-top) + 6rem));
    padding-bottom: 0;
    background:
      radial-gradient(48rem 34rem at 12% 6%, rgb(240 212 147 / 0.20), transparent 58%),
      radial-gradient(42rem 32rem at 88% 20%, rgb(217 177 90 / 0.18), transparent 55%),
      radial-gradient(56rem 42rem at 72% 98%, rgb(168 123 46 / 0.26), transparent 60%),
      linear-gradient(168deg, #16161a 0%, #0b0b0c 58%, #050506 100%);
    color: var(--paper);
    overflow: clip;
  }

  .hero-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(85px);
    mix-blend-mode: screen; /* ouro se funde no fundo escuro */
  }

  .blob-1 {
    width: 42rem;
    height: 42rem;
    left: -13rem;
    top: -12rem;
    background: rgb(240 212 147 / 0.26);
  }

  .blob-2 {
    width: 34rem;
    height: 34rem;
    right: -11rem;
    bottom: -8rem;
    background: rgb(217 177 90 / 0.4);
  }

  .blob-3 {
    width: 30rem;
    height: 30rem;
    left: 40%;
    top: 36%;
    background: rgb(168 123 46 / 0.34);
  }

  @media (prefers-reduced-motion: no-preference) {
    .blob-1 {
      animation: blob-drift 16s ease-in-out infinite alternate;
    }

    .blob-2 {
      animation: blob-drift 19s ease-in-out infinite alternate-reverse;
    }

    .blob-3 {
      animation: blob-drift 23s ease-in-out infinite alternate;
    }
  }

  @keyframes blob-drift {
    to {
      transform: translate(3rem, 2rem) scale(1.08);
    }
  }

  .hero-diamonds {
    position: absolute;
    width: min(120vmin, 56rem);
    height: auto;
    right: -18%;
    top: 50%;
    translate: 0 -50%;
  }

  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .hero-diamonds {
        animation: diamond-spin linear both;
        animation-timeline: view(block 0%);
      }
    }
  }

  @keyframes diamond-spin {
    to {
      transform: translateY(-12rem) rotate(14deg);
    }
  }

  @media (max-width: 720px) {
    .hero-diamonds {
      width: 150vmin;
      right: -65%;
    }
  }

  /* celular: mobile é o canal principal — entra no fluxo, logo depois do CTA;
     no desktop vira a peça absoluta da direita */
  .hero-phone {
    order: 2;
    width: min(64vw, 248px);
    margin: 2.8rem auto 0;
    pointer-events: none;
  }

  .hero-inner {
    order: 1;
  }

  @media (min-width: 960px) {
    .hero-phone {
      position: absolute;
      right: clamp(0rem, 3vw, 5rem);
      top: 50%;
      translate: 0 -50%;
      width: min(30vw, 320px);
      margin: 0;
      z-index: 1;
    }

    .hero-diamonds {
      display: none;
    }

    .hero-inner {
      padding-right: min(34vw, 420px);
    }
  }

  .hero-inner {
    position: relative;
    padding-bottom: clamp(5rem, 11vh, 7rem);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--yellow);
    border: 1px solid rgb(217 177 90 / 0.4);
    border-radius: 999px;
    padding: 0.5em 1.1em;
    margin-bottom: 1.8rem;
    background: rgb(217 177 90 / 0.06);
  }

  .hero-eyebrow .dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--yellow);
    flex: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-eyebrow .dot {
      animation: dot-pulse 2.2s ease-in-out infinite;
    }
  }

  @keyframes dot-pulse {
    50% {
      transform: scale(1.6);
      opacity: 0.55;
    }
  }

  .hero-title {
    font-size: var(--text-hero);
    max-width: 12ch;
    letter-spacing: -0.015em;
  }

  .hero-line {
    display: block;
  }

  .hero-line--ghost {
    opacity: 0.95;
  }

  .w {
    display: inline-block;
  }

  .w-accent {
    position: relative;
    color: var(--gold);
    background: var(--gold-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
    .w-accent {
      -webkit-text-fill-color: var(--gold);
    }
  }

  .swoosh {
    position: absolute;
    left: -2%;
    right: -4%;
    bottom: -0.18em;
    width: 104%;
    height: 0.22em;
  }

  .swoosh path {
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .swoosh path {
      stroke-dashoffset: 1;
      animation: swoosh-draw 0.55s var(--ease-out) 1.1s forwards;
    }
  }

  @keyframes swoosh-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--muted-on-dark);
    max-width: 34ch;
    margin-top: 1.6rem;
  }

  .hero-sub strong {
    color: var(--paper);
  }

  .hero-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    margin: 1.6rem 0 0;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--paper);
    background: rgb(255 255 255 / 0.07);
    border: 1px solid rgb(255 255 255 / 0.16);
    border-radius: 999px;
    padding: 0.45em 1em;
    backdrop-filter: blur(6px);
  }

  .chip svg {
    width: 0.95em;
    height: 0.95em;
    color: var(--yellow);
  }

  @media (prefers-reduced-motion: no-preference) {
    .chip {
      animation: chip-float 6.5s ease-in-out infinite;
      animation-delay: calc(var(--f) * 1.1s);
    }
  }

  @keyframes chip-float {
    50% {
      transform: translateY(-7px);
    }
  }

  .hero-cta {
    margin-top: 2.4rem;
  }

  .hero .microcopy {
    color: var(--muted-on-dark);
  }

  .hero .microcopy strong {
    color: var(--yellow);
  }

  .hero-time {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.6rem;
    padding: 0.5em 0.95em;
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.04);
    font-size: 0.84rem;
    color: var(--muted-on-dark);
    backdrop-filter: blur(4px);
  }

  .hero-time strong {
    color: var(--paper);
    font-weight: 700;
  }

  .hero-time svg {
    width: 1em;
    height: 1em;
    color: var(--yellow);
    flex: none;
  }

  .scroll-cue {
    order: 3;
    width: 2.9rem;
    height: 2.9rem;
    margin: 2.2rem auto 0;
    display: grid;
    place-items: center;
    color: var(--paper);
    border: 1.5px solid rgb(255 255 255 / 0.3);
    border-radius: 50%;
    z-index: 3;
  }

  @media (min-width: 960px) {
    .scroll-cue {
      position: absolute;
      left: 50%;
      bottom: 4.2rem;
      translate: -50% 0;
      margin: 0;
    }
  }

  .scroll-cue svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue svg {
      animation: cue-bounce 2s ease-in-out infinite;
    }
  }

  @keyframes cue-bounce {
    50% {
      transform: translateY(4px);
    }
  }

  .hero-marquee {
    position: relative;
    z-index: 3;
    margin-top: auto;
    order: 4;
  }

  /* Entrada na carga — CSS puro, escalonada por --i */
  @media (prefers-reduced-motion: no-preference) {
    .w,
    .anim-up {
      opacity: 0;
      transform: translateY(0.55em);
      animation: hero-in 0.7s var(--ease-out) forwards;
      animation-delay: calc(var(--i) * 90ms + 120ms);
    }

    .anim-up {
      transform: translateY(18px);
    }
  }

  @keyframes hero-in {
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
