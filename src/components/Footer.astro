---
/**
 * Rodapé: logo, aviso de modelo (autônomo, sem vínculo), links legais, LGPD.
 */
import Logo from './Logo.astro';
import {
  CLOSING_LABEL,
  LEGAL_NAME,
  CNPJ,
  CONTACT_EMAIL,
  CONTACT_WHATSAPP,
} from '../config';

const year = new Date().getFullYear();

// linha de identificação do fornecedor: só inclui o que existe de fato.
// CNPJ ausente NÃO vira placeholder — some até a env real ser preenchida.
const waHref = CONTACT_WHATSAPP ? `https://wa.me/${CONTACT_WHATSAPP}` : null;
const waLabel = CONTACT_WHATSAPP
  ? CONTACT_WHATSAPP.replace(/^55(\d{2})(\d{4,5})(\d{4})$/, '($1) $2-$3')
  : null;
const legalParts = [
  `${LEGAL_NAME} · Programa de Promotores`,
  CNPJ ? `CNPJ ${CNPJ}` : null,
].filter(Boolean);
---

<footer class="footer on-dark">
  <div class="container">
    <p class="footer-tag">
      Feito para quem quer <span>ganhar indicando.</span>
    </p>

    <div class="footer-top">
      <div class="footer-brand">
        <Logo variant="light" />
        <!-- selo dourado: assinatura de fechamento -->
        <svg class="footer-flag" viewBox="0 0 64 64" fill="none" aria-hidden="true">
          <path d="M32 6 58 32 32 58 6 32Z" fill="none" stroke="var(--gold)" stroke-width="2.4" stroke-linejoin="round"></path>
          <path d="M32 16 48 32 32 48 16 32Z" fill="var(--gold)" opacity="0.12"></path>
          <path d="M24 32l6 6 12-13" stroke="var(--gold)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
      <nav aria-label="Links legais" class="footer-nav">
        <div class="footer-nav-group">
          <p class="footer-nav-title">O programa</p>
          <a href="#como-funciona">Como funciona</a>
          <a href="#ganhos">Quanto dá pra ganhar</a>
          <a href="#caminho">Como entrar</a>
        </div>
        <div class="footer-nav-group">
          <p class="footer-nav-title">Legal</p>
          <a href="/termos/">Termos do Programa</a>
          <a href="/privacidade/">Política de Privacidade</a>
        </div>
      </nav>
      <a class="to-top" href="#hero" aria-label="Voltar ao topo">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 19V5m-6 6 6-6 6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="footer-legal">
      <p class="footer-id">
        {legalParts.join(' · ')} ·{' '}
        <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        {waHref && (
          <>
            {' · '}
            <a href={waHref} rel="noopener" target="_blank">WhatsApp {waLabel}</a>
          </>
        )}
      </p>
      <p>
        O Programa de Promotores remunera por <strong>indicação de matrículas
        pagas</strong>, com pagamento por Pix {CLOSING_LABEL}. A participação é
        autônoma e voluntária: <strong>não há vínculo empregatício</strong>,
        exclusividade ou obrigação de meta. Os valores de comissão e bônus podem
        ser ajustados; valem sempre os exibidos no painel do promotor.
      </p>
      <p>
        Para receber, você cadastra uma chave Pix no seu próprio CPF, validada
        junto ao banco (DICT). Os dados informados no cadastro (CPF, contato,
        documento, selfie e chave Pix) são usados apenas para identificação,
        pagamento e prevenção a fraude, conforme a LGPD (Lei nº 13.709/2018).
      </p>
      <p class="footer-copy">© {year} V7M. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--muted-on-dark);
    padding-block: 3.6rem 2.6rem;
    font-size: 0.86rem;
    /* faixa tricolor: assinatura da bandeira fechando a página */
    border-top: 5px solid transparent;
    border-image: linear-gradient(
        90deg,
        var(--green) 0 34%,
        var(--yellow) 34% 67%,
        var(--blue) 67% 100%
      )
      1;
  }

  /* tagline de fechamento — a única frase grande do rodapé */
  .footer-tag {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 1.15;
    color: var(--paper);
    max-width: 16ch;
    margin-bottom: 2.4rem;
  }

  .footer-tag span {
    color: var(--yellow);
  }

  /* espaço para o sticky CTA não cobrir o rodapé no mobile */
  @media (max-width: 899px) {
    .footer {
      padding-bottom: 7rem;
    }
  }

  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
  }

  /* logo um degrau maior que o do header — assinatura de fechamento */
  .footer-top :global(.logo svg) {
    width: 40px;
    height: 40px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  /* bandeirinha no mastro, ondulando de leve */
  .footer-flag {
    width: 52px;
    height: auto;
    overflow: visible;
  }

  .ff-cloth {
    transform-box: view-box;
    transform-origin: 8px 26px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ff-cloth {
      animation: ff-wave 4.5s ease-in-out infinite;
    }
  }

  @keyframes ff-wave {
    0%,
    100% {
      transform: skewY(0deg);
    }
    30% {
      transform: skewY(2.4deg) scaleX(0.985);
    }
    65% {
      transform: skewY(-1.8deg);
    }
  }

  .footer-nav {
    display: flex;
    gap: clamp(2rem, 6vw, 4rem);
  }

  .footer-nav-group {
    display: grid;
    gap: 0.15rem;
    justify-items: start;
  }

  .footer-nav-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.5);
    margin-bottom: 0.35rem;
  }

  .footer-nav a {
    color: var(--paper);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    /* área de toque ≥ 44px sem inflar o layout */
    display: inline-block;
    padding-block: 0.55rem;
    margin-block: -0.25rem;
  }

  .footer-nav a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* voltar ao topo: eco do scroll-cue do hero */
  .to-top {
    width: 3rem;
    height: 3rem;
    flex: none;
    display: grid;
    place-items: center;
    color: var(--paper);
    border: 1.5px solid rgb(255 255 255 / 0.3);
    border-radius: 50%;
    transition:
      transform 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      color 0.2s var(--ease-out);
  }

  .to-top svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .to-top:hover {
    transform: translateY(-3px);
    border-color: var(--yellow);
    color: var(--yellow);
  }

  .to-top:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 3px;
  }

  .footer-legal {
    margin-top: 1.8rem;
    display: grid;
    gap: 0.7rem;
    max-width: 60ch;
  }

  .footer-legal strong {
    color: var(--paper);
  }

  .footer-id a {
    color: var(--paper);
    text-decoration: underline;
    text-underline-offset: 3px;
    /* área de toque sem inflar layout */
    display: inline-block;
    padding-block: 0.3rem;
    margin-block: -0.3rem;
  }

  .footer-id a:hover {
    color: var(--yellow);
  }

  .footer-id a:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .footer-copy {
    margin-top: 0.6rem;
  }
</style>
